{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baseline.local/schemas/mission-control-session.schema.json",
  "title": "Mission Control Session",
  "type": "object",
  "schema_version": "mission-control/v2",
