      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "decision_receipts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "context_stack": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "human_interactions": {
      "type": "array",
      "items": {
        "type": "object"
      }
