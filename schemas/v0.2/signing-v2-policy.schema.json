{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile", "verification_time", "trusted_root_sha256", "trusted_subjects",
    "authorized_tsa_subjects", "required_scopes", "minimum_authorized_signatures",
    "require_archival_time", "archival_before", "signers", "timestamp_authorities",
    "crls", "timestamps", "countersignatures"
  ],
  "properties": {
    "profile": {"const": "aecctx-x509-ed25519-crl-time-v1"},
    "verification_time": {"type": "string", "format": "date-time"},
    "archival_before": {"type": "string", "format": "date-time"},
    "minimum_authorized_signatures": {"type": "integer", "minimum": 1, "maximum": 64},
    "require_archival_time": {"type": "boolean"},
    "trusted_root_sha256": {"$ref": "#/$defs/digests"},
    "trusted_subjects": {"$ref": "#/$defs/strings"},
    "authorized_tsa_subjects": {"$ref": "#/$defs/strings"},
    "required_scopes": {"$ref": "#/$defs/strings"},
    "signers": {
      "type": "array", "minItems": 1, "maxItems": 64,
      "items": {"$ref": "#/$defs/signer"}
    },
    "timestamp_authorities": {
      "type": "array", "maxItems": 64,
      "items": {"$ref": "#/$defs/authority"}
    },
    "crls": {"type": "array", "maxItems": 64, "items": {"type": "string", "maxLength": 1398104}},
    "timestamps": {
      "type": "array", "maxItems": 64,
      "items": {"$ref": "#/$defs/timestamp"}
    },
    "countersignatures": {
      "type": "array", "maxItems": 64,
      "items": {"$ref": "#/$defs/countersignature"}
    }
  },
  "$defs": {
    "strings": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 512}},
    "digests": {"type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "chain": {"type": "array", "minItems": 2, "maxItems": 3, "items": {"type": "string", "maxLength": 1398104}},
    "authority": {
      "type": "object", "additionalProperties": false, "required": ["kid", "chain"],
      "properties": {"kid": {"type": "string", "minLength": 1, "maxLength": 128}, "chain": {"$ref": "#/$defs/chain"}}
    },
    "signer": {
      "type": "object", "additionalProperties": false, "required": ["kid", "chain", "scopes"],
      "properties": {"kid": {"type": "string", "minLength": 1, "maxLength": 128}, "chain": {"$ref": "#/$defs/chain"}, "scopes": {"$ref": "#/$defs/strings"}}
    },
    "timestamp": {
      "type": "object", "additionalProperties": false,
      "required": ["profile", "kid", "target_kind", "target_sha256", "gen_time", "tsa_certificate_sha256", "signature"],
      "properties": {
        "profile": {"const": "aecctx-trusted-time-v1"}, "kid": {"type": "string", "minLength": 1, "maxLength": 128},
        "target_kind": {"enum": ["statement", "signature"]}, "target_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "gen_time": {"type": "string", "format": "date-time"}, "tsa_certificate_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "signature": {"type": "string", "pattern": "^[A-Za-z0-9_-]{86}$"}
      }
    },
    "countersignature": {
      "type": "object", "additionalProperties": false,
      "required": ["profile", "kid", "target_signature_sha256", "signature"],
      "properties": {
        "profile": {"const": "aecctx-countersignature-v1"}, "kid": {"type": "string", "minLength": 1, "maxLength": 128},
        "target_signature_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "signature": {"type": "string", "pattern": "^[A-Za-z0-9_-]{86}$"}
      }
    }
  }
}
