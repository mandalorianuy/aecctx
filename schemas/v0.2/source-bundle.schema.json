{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aecctx.dev/schemas/v0.2/source-bundle.schema.json",
  "title": "AECCTX content-addressed source bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "root", "entries"],
  "properties": {
    "version": {"const": "0.2"},
    "root": {"$ref": "#/$defs/path"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {"$ref": "#/$defs/entry"}
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*://)[^\\u0000]+$"
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "media_type", "bytes", "sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/path"},
        "role": {"enum": ["root", "xref"]},
        "media_type": {"enum": ["application/dxf", "application/x-dxf"]},
        "bytes": {"type": "integer", "minimum": 1, "maximum": 536870912},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
