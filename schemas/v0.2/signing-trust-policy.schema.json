{
  "$id": "https://aecctx.dev/schemas/v0.2/signing-trust-policy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_algorithms": {"items": {"const": "Ed25519"}, "maxItems": 1, "minItems": 1, "type": "array", "uniqueItems": true},
    "minimum_authorized_signatures": {"maximum": 64, "minimum": 1, "type": "integer"},
    "policy_version": {"const": "1"},
    "required_scopes": {"items": {"maxLength": 256, "minLength": 1, "type": "string"}, "maxItems": 64, "type": "array", "uniqueItems": true},
    "trusted_kids": {"items": {"maxLength": 256, "minLength": 1, "type": "string"}, "maxItems": 1024, "type": "array", "uniqueItems": true},
    "trusted_subjects": {"items": {"maxLength": 1024, "minLength": 1, "type": "string"}, "maxItems": 1024, "type": "array", "uniqueItems": true},
    "verification_time": {"format": "date-time", "type": "string"}
  },
  "required": ["policy_version", "verification_time", "allowed_algorithms", "trusted_kids", "trusted_subjects", "required_scopes", "minimum_authorized_signatures"],
  "title": "AECCTX offline signing trust policy v1",
  "type": "object"
}
