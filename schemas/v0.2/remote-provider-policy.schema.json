{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aecctx.dev/schemas/v0.2/remote-provider-policy.schema.json",
  "title": "AECCTX remote provider policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "allowed_regions", "billing_consent", "endpoint_origin", "endpoint_spki_sha256",
    "expected_region", "max_attempts", "max_request_bytes", "max_response_bytes",
    "retention_max_seconds", "retry_delay_seconds", "telemetry_consent",
    "timeout_seconds", "upload_consent"
  ],
  "properties": {
    "allowed_regions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"}},
    "billing_consent": {"type": "boolean"},
    "endpoint_origin": {"type": "string", "minLength": 1, "maxLength": 2048},
    "endpoint_spki_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "expected_region": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"},
    "max_attempts": {"type": "integer", "minimum": 1, "maximum": 3},
    "max_request_bytes": {"type": "integer", "minimum": 1, "maximum": 1073741824},
    "max_response_bytes": {"type": "integer", "minimum": 1, "maximum": 1073741824},
    "retention_max_seconds": {"type": "integer", "minimum": 0, "maximum": 31536000},
    "retry_delay_seconds": {"type": "number", "minimum": 0, "maximum": 60},
    "telemetry_consent": {"type": "boolean"},
    "timeout_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 3600},
    "upload_consent": {"type": "boolean"}
  }
}
