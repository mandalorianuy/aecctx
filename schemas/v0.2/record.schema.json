{
  "$id": "https://aecctx.dev/schemas/v0.2/record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "provenance": {
      "additionalProperties": false,
      "properties": {
        "method": {"minLength": 1, "type": "string"},
        "parent_record_ids": {"items": {"type": "string"}, "type": "array", "uniqueItems": true},
        "producer_id": {"minLength": 1, "type": "string"},
        "producer_version": {"minLength": 1, "type": "string"},
        "recorded_at": {"format": "date-time", "type": "string"}
      },
      "required": ["producer_id", "producer_version", "method", "recorded_at", "parent_record_ids"],
      "type": "object"
    },
    "source_ref": {
      "additionalProperties": false,
      "properties": {
        "locator": {"minLength": 1, "type": "string"},
        "source_id": {"minLength": 1, "type": "string"}
      },
      "required": ["source_id", "locator"],
      "type": "object"
    },
    "value_state": {
      "additionalProperties": true,
      "oneOf": [
        {"properties": {"state": {"const": "known"}}, "required": ["state", "value"]},
        {"properties": {"state": {"enum": ["unknown", "not_applicable", "conflicted", "explicit_null", "unsupported"]}, "reason_code": {"minLength": 1, "type": "string"}}, "required": ["state", "reason_code"]}
      ],
      "type": "object"
    },
    "qualified_value": {
      "allOf": [{"$ref": "#/$defs/value_state"}],
      "properties": {
        "authority": {"enum": ["source_declared", "detected", "manual", "derived"]}
      },
      "required": ["authority"],
      "type": "object"
    },
    "inference": {
      "additionalProperties": false,
      "properties": {
        "execution_mode": {"enum": ["local", "network"]},
        "extraction_confidence": {"maximum": 1, "minimum": 0, "type": "number"},
        "input_artifact_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "input_region_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "interpretation_confidence": {"maximum": 1, "minimum": 0, "type": "number"},
        "model_version": {"minLength": 1, "type": "string"},
        "provider_id": {"minLength": 1, "type": "string"},
        "provider_version": {"minLength": 1, "type": "string"},
        "reproducibility": {"enum": ["deterministic", "seeded", "non_deterministic"]},
        "request_digest": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "response_digest": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "verification_state": {"enum": ["unverified", "verified", "rejected"]}
      },
      "required": [
        "input_artifact_sha256", "input_region_sha256", "provider_id", "provider_version",
        "execution_mode", "request_digest", "response_digest", "extraction_confidence",
        "interpretation_confidence", "reproducibility", "verification_state"
      ],
      "type": "object"
    },
    "transform_link": {
      "additionalProperties": false,
      "oneOf": [
        {
          "properties": {
            "from_frame": {"minLength": 1, "type": "string"},
            "matrix": {"items": {"type": "number"}, "maxItems": 16, "minItems": 16, "type": "array"},
            "state": {"const": "known"},
            "to_frame": {"minLength": 1, "type": "string"}
          },
          "required": ["from_frame", "to_frame", "state", "matrix"]
        },
        {
          "properties": {
            "from_frame": {"minLength": 1, "type": "string"},
            "reason_code": {"minLength": 1, "type": "string"},
            "state": {"enum": ["unknown", "not_applicable", "conflicted", "explicit_null", "unsupported"]},
            "to_frame": {"minLength": 1, "type": "string"}
          },
          "required": ["from_frame", "to_frame", "state", "reason_code"]
        }
      ],
      "type": "object"
    },
    "coordinate_qualification": {
      "additionalProperties": false,
      "properties": {
        "axis_order": {"$ref": "#/$defs/qualified_value"},
        "declared_crs": {"allOf": [{"$ref": "#/$defs/qualified_value"}, {"properties": {"authority": {"const": "source_declared"}}}]},
        "declared_units": {"allOf": [{"$ref": "#/$defs/qualified_value"}, {"properties": {"authority": {"const": "source_declared"}}}]},
        "detected_crs": {"allOf": [{"$ref": "#/$defs/qualified_value"}, {"properties": {"authority": {"const": "detected"}}}]},
        "detected_units": {"allOf": [{"$ref": "#/$defs/qualified_value"}, {"properties": {"authority": {"const": "detected"}}}]},
        "global_location": {"$ref": "#/$defs/value_state"},
        "handedness": {"$ref": "#/$defs/qualified_value"},
        "horizontal_crs": {"$ref": "#/$defs/qualified_value"},
        "manual_crs": {"allOf": [{"$ref": "#/$defs/qualified_value"}, {"properties": {"authority": {"const": "manual"}}}]},
        "manual_units": {"allOf": [{"$ref": "#/$defs/qualified_value"}, {"properties": {"authority": {"const": "manual"}}}]},
        "origin": {"$ref": "#/$defs/qualified_value"},
        "scale": {"$ref": "#/$defs/qualified_value"},
        "tolerance": {"$ref": "#/$defs/qualified_value"},
        "transform_chain": {"items": {"$ref": "#/$defs/transform_link"}, "type": "array"},
        "transform_direction": {"$ref": "#/$defs/qualified_value"},
        "vertical_crs": {"$ref": "#/$defs/qualified_value"}
      },
      "required": ["global_location", "transform_chain"],
      "type": "object"
    },
    "representation_fidelity": {
      "additionalProperties": false,
      "properties": {
        "class": {"enum": ["source_exact", "parametric", "brep", "tessellated", "rasterized", "projection_2d", "preview", "inferred"]},
        "derived": {"type": "boolean"},
        "source_representation_ids": {"items": {"minLength": 1, "type": "string"}, "minItems": 1, "type": "array", "uniqueItems": true}
      },
      "required": ["class", "derived", "source_representation_ids"],
      "type": "object"
    },
    "provider_attestation": {
      "additionalProperties": false,
      "properties": {
        "deterministic": {"type": "boolean"},
        "execution_mode": {"enum": ["local", "network"]},
        "network_mode": {"enum": ["disabled", "allowlisted"]},
        "provider_id": {"minLength": 1, "type": "string"},
        "provider_version": {"minLength": 1, "type": "string"},
        "request_digest": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "response_digest": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "runtime_version": {"minLength": 1, "type": "string"}
      },
      "required": ["provider_id", "provider_version", "runtime_version", "execution_mode", "network_mode", "deterministic", "request_digest", "response_digest"],
      "type": "object"
    }
  },
  "additionalProperties": true,
  "properties": {
    "coordinate_qualification": {"$ref": "#/$defs/coordinate_qualification"},
    "evidence_class": {"enum": ["observed", "inferred", "manual", "derived"]},
    "extensions": {"type": "object"},
    "inference": {"$ref": "#/$defs/inference"},
    "provenance": {"$ref": "#/$defs/provenance"},
    "record_id": {"minLength": 1, "type": "string"},
    "record_type": {"enum": ["source", "primitive", "assertion", "entity", "relation", "diagnostic", "unsupported"]},
    "record_version": {"const": "0.2"},
    "representation_fidelity": {"$ref": "#/$defs/representation_fidelity"},
    "provider_attestation": {"$ref": "#/$defs/provider_attestation"},
    "source_refs": {"items": {"$ref": "#/$defs/source_ref"}, "type": "array"}
  },
  "allOf": [
    {
      "if": {"properties": {"evidence_class": {"const": "inferred"}}, "required": ["evidence_class"]},
      "then": {"required": ["inference"]}
    },
    {
      "if": {"required": ["inference"]},
      "then": {"properties": {"evidence_class": {"const": "inferred"}}}
    }
  ],
  "required": ["record_version", "record_id", "record_type", "source_refs", "provenance", "evidence_class"],
  "title": "AECCTX v0.2 common record",
  "type": "object"
}
