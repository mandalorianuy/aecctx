{
  "$id": "https://aecctx.dev/schemas/v0.2/signature-bundle.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "signatures": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "protected": {"maxLength": 2048, "minLength": 1, "type": "string"},
          "signature": {"pattern": "^[A-Za-z0-9_-]{86}$", "type": "string"}
        },
        "required": ["protected", "signature"],
        "type": "object"
      },
      "maxItems": 64,
      "minItems": 1,
      "type": "array"
    }
  },
  "required": ["signatures"],
  "title": "AECCTX detached JWS signature bundle v1",
  "type": "object"
}
